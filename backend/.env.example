# Deskly API environment
PORT=4000
NODE_ENV=development

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=debug

# CORS origin for the Next.js web app
WEB_ORIGIN=http://localhost:3000

# PostgreSQL (tickets repository runs on this; see docker-compose.yml)
DATABASE_URL=postgresql://deskly:deskly@localhost:5432/deskly?schema=public

# Storage adapter: "local" (dev) or "s3" (prod / S3-compatible like MinIO)
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./.uploads
# S3 settings (only used when STORAGE_DRIVER=s3). S3_BUCKET is required.
# For real AWS S3, set S3_REGION and leave endpoint/keys unset to use the IAM
# credential chain. For MinIO/S3-compatible, set S3_ENDPOINT + path-style + keys.
# S3_BUCKET=deskly-attachments
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000
# S3_FORCE_PATH_STYLE=true
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_PUBLIC_URL=https://cdn.example.com   # optional; else s3://bucket/key

# Auth secrets. The values below are DEV FALLBACKS — fine for `npm run dev`, but
# with NODE_ENV=production the API refuses to boot unless both are set, unique,
# not these defaults, and >=32 chars. Generate real ones: `openssl rand -base64 48`.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
ACCESS_TTL_SEC=900
REFRESH_TTL_SEC=604800
# Refresh-cookie Secure flag. Leave unset to follow NODE_ENV (on in production).
# Set false when running production mode without TLS (e.g. docker-compose over HTTP).
# COOKIE_SECURE=false
# Max login attempts per IP per 15-min window (brute-force guard)
AUTH_RATE_LIMIT=20

# Log aggregation. Structured JSON always goes to stdout; set LOKI_URL to ALSO
# ship logs to a Grafana Loki endpoint (basic-auth optional, e.g. Grafana Cloud).
# Leave unset for stdout only. See docker-compose.logging.yml for a local stack.
# LOKI_URL=http://localhost:3100
# LOKI_USERNAME=
# LOKI_PASSWORD=

# External ticket sources (future integrations). Each is a pluggable adapter
# under src/modules/integrations; unset = provider shows as "not configured".
# The Jira/Zendesk REST calls are stubbed until implemented. A built-in "mock"
# source needs no config and is always available for demoing the sync pipeline.
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=you@your-org.com
# JIRA_API_TOKEN=            # https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_JQL=project = SUP AND status != Done
# ZENDESK_SUBDOMAIN=your-org # -> https://your-org.zendesk.com
# ZENDESK_EMAIL=you@your-org.com
# ZENDESK_API_TOKEN=

# Email-to-ticket (webhook / push). Set EMAIL_WEBHOOK_SECRET to enable the
# inbound endpoint POST /api/v1/integrations/email-inbound — point your email
# provider's inbound-parse route (SendGrid/Mailgun/Postmark) at it and have it
# send the secret in the `x-webhook-secret` header (or `?secret=`). Unknown
# senders become requester users unless EMAIL_CREATE_UNKNOWN_REQUESTER=false.
# EMAIL_WEBHOOK_SECRET=change-me-long-random
# EMAIL_DEFAULT_CATEGORY=Email
# EMAIL_CREATE_UNKNOWN_REQUESTER=true

# Email-to-ticket (IMAP / pull). Scaffolded adapter — unset = "not configured".
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USER=helpdesk@example.com
# IMAP_PASSWORD=
# IMAP_TLS=true

# Outbound SMTP for agent reply emails. Unset = a "log" transport records the
# message instead of sending (dev). Set these to send real mail via nodemailer.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false          # true for port 465 (implicit TLS)
# SMTP_USER=helpdesk@example.com
# SMTP_PASSWORD=
# SMTP_FROM=Deskly Support <helpdesk@example.com>

# Real-time event bus for the SSE comment stream. Unset = in-process (single
# node). Set a Redis URL to fan events out across multiple API instances via
# Redis pub/sub (required when running more than one API replica).
# REDIS_URL=redis://redis:6379
